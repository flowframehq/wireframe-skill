{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowframe.dev/schema/flowframe-meta.schema.json",
  "title": "FlowFrame Wireframe Metadata",
  "description": "FlowFrame 와이어프레임 HTML 파일의 메타데이터 스키마. <script type=\"application/json\" id=\"flowframe-meta\"> 블록에 삽입된다.",
  "type": "object",
  "required": ["generator", "version", "type", "screenId", "title", "purpose", "features"],
  "properties": {
    "generator": {
      "type": "string",
      "const": "flowframe-wireframe-skill",
      "description": "생성기 식별 고정값."
    },
    "version": {
      "type": "string",
      "const": "2.0",
      "description": "메타데이터 버전."
    },
    "type": {
      "type": "string",
      "enum": ["screen", "modal"],
      "description": "와이어프레임 유형. screen: 일반 화면, modal: 모달 다이얼로그."
    },
    "screenId": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9-]*$",
      "description": "화면 식별자 (예: LOGIN, CHECKOUT, PRODUCT-LIST). 순차 번호(001, 002 등) 금지 — reviewer S7이 검증."
    },
    "title": {
      "type": "string",
      "description": "화면 제목."
    },
    "purpose": {
      "type": "string",
      "description": "화면 목적 한 줄 설명."
    },
    "modalId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "모달 식별자. type이 modal이면 필수."
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "description": "이 화면의 피처 목록. 재귀적 구조로 하위 피처를 포함할 수 있다.",
      "items": {
        "$ref": "#/$defs/Feature"
      }
    },
    "author": {
      "type": "string",
      "description": "작성자 이름 (선택)."
    },
    "viewport": {
      "type": "string",
      "enum": ["pc", "mobile"],
      "description": "대상 뷰포트 (선택)."
    }
  },
  "additionalProperties": false,
  "if": {
    "properties": { "type": { "const": "modal" } },
    "required": ["type"]
  },
  "then": {
    "required": ["modalId"]
  },
  "$defs": {
    "Feature": {
      "type": "object",
      "required": ["featureId", "label"],
      "anyOf": [
        { "required": ["elements"] },
        { "required": ["features"] }
      ],
      "properties": {
        "featureId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*(__[A-Z][A-Z0-9_]*)*$",
          "description": "TOC 경로에서 파생한 피처 ID. 이중 밑줄(__) 로 깊이 구분 (예: AUTH__LOGIN__EMAIL_LOGIN)."
        },
        "label": {
          "type": "string",
          "description": "피처 표시명 (한국어, data-label 값)."
        },
        "elements": {
          "type": "array",
          "minItems": 1,
          "description": "이 피처에 속하는 와이어프레임 요소.",
          "items": {
            "$ref": "#/$defs/Element"
          }
        },
        "features": {
          "type": "array",
          "minItems": 1,
          "description": "하위 피처 목록 (재귀).",
          "items": {
            "$ref": "#/$defs/Feature"
          }
        }
      },
      "additionalProperties": false
    },
    "Element": {
      "type": "object",
      "required": ["id", "type", "label", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "description": "요소 ID. 부모 data-feature 스코프 내 유니크한 짧은 키 (예: EMAIL, SUBMIT, CODE). DOM에서 data-el 속성값과 일치."
        },
        "type": {
          "type": "string",
          "description": "와이어프레임 요소 타입. 일반적인 값: input, button, text, select, checkbox, radio, table, list, link, image, textarea, toggle."
        },
        "label": {
          "type": "string",
          "description": "와이어프레임 패널에 표시되는 요소 이름."
        },
        "description": {
          "type": "string",
          "description": "이 화면에서 요소가 수행하는 기능적 역할에 대한 설명."
        }
      },
      "additionalProperties": false
    }
  }
}
